      "RuleId": "template-injection",
      "Title": "expression-injection: Untrusted input in run step",
      "Severity": "High",
      "Compliant": false,
      "Detail": "Expression '${{ github.event.pull_request.title }}' in run step is vulnerable to injection (file: .github/workflows/ci.yml)",
      "Remediation": "Use an environment variable instead of directly interpolating the expression in the run step.",
      "ResourceId": ".github/workflows/ci.yml",
      "LearnMoreUrl": "https://docs.zizmor.sh/audits/#template-injection",
      "Pillar": "Security",
      "Impact": "High",
      "Effort": "Low",
      "DeepLinkUrl": "https://docs.zizmor.sh/audits/#template-injection",
      "RemediationSnippets": [
        {
          "language": "yaml",
          "before": "steps:\n  - run: echo \"${{ github.event.pull_request.title }}\"",
          "after": "steps:\n  - env:\n      PR_TITLE: ${{ github.event.pull_request.title }}\n    run: echo \"$PR_TITLE\""
        }
      ],
