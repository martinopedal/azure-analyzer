          "manager": "brew",
          "package": "Azure/kubelogin/kubelogin"
        },
        "linux": {
          "manager": "script",
          "url": "https://github.com/Azure/kubelogin/releases"
        }
      },
      "fallback": "az aks install-cli  (also installs kubectl)"
    }
  ]
}
